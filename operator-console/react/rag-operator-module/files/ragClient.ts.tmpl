const CONTEXT_BASE = import.meta.env.VITE_CONTEXT_SERVICE_URL || 'http://localhost:18001';

export type RAGCitation = { source?: string; excerpt?: string; score?: number };
export type RAGSynthesisResult = {
  answer: string;
  citations?: RAGCitation[];
  provenance?: Record<string, unknown>;
  eval?: Record<string, unknown>;
};

export async function synthesizeQuery(query: string, partition?: string): Promise<RAGSynthesisResult> {
  const resp = await fetch(`${CONTEXT_BASE}/context/rag/synthesize`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ query, partition: partition || 'default', top_k: 8 }),
  });
  if (!resp.ok) {
    throw new Error(`RAG synthesis failed: HTTP ${resp.status}`);
  }
  return resp.json() as Promise<RAGSynthesisResult>;
}
