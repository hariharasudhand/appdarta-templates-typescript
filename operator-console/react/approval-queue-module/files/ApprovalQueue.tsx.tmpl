import { useState, useEffect, useCallback } from 'react';
import { Link } from 'react-router-dom';
import { fetchPendingApprovals } from '../api/approvalClient';
import { APPROVAL_GATE, mustGate } from '../config/approvalGate';
import type { ApprovalItem } from '../config/approvalGate';

type StatusFilter = 'all' | 'pending' | 'escalated';

const POLL_MS = 10_000;
const STALE_MS = 30_000;

export default function ApprovalQueue() {
  const [items, setItems]           = useState<ApprovalItem[]>([]);
  const [filter, setFilter]         = useState<StatusFilter>('pending');
  const [lastFetch, setLastFetch]   = useState<number>(0);
  const [error, setError]           = useState<string | null>(null);

  const load = useCallback(async () => {
    try {
      const data = await fetchPendingApprovals();
      setItems(data);
      setLastFetch(Date.now());
      setError(null);
    } catch {
      setError('Failed to load approval queue — retrying.');
    }
  }, []);

  useEffect(() => {
    load();
    const id = setInterval(load, POLL_MS);
    return () => clearInterval(id);
  }, [load]);

  const isStale = lastFetch > 0 && Date.now() - lastFetch > STALE_MS;

  const visible = items.filter((it) =>
    filter === 'all' ? true : it.status === filter,
  );

  return (
    <div>
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 16 }}>
        <h1 style={{ margin: 0, fontSize: 22, fontWeight: 700 }}>Approval Queue</h1>
        <span style={{ fontSize: 12, color: '#64748b' }}>
          Auto-refreshes every {POLL_MS / 1000}s
        </span>
      </div>

      {isStale && (
        <div style={{ padding: '8px 12px', background: '#fef3c7', borderRadius: 6, marginBottom: 12, fontSize: 13 }}>
          Data may be stale — last fetched {Math.round((Date.now() - lastFetch) / 1000)}s ago.
        </div>
      )}
      {error && (
        <div style={{ padding: '8px 12px', background: '#fee2e2', borderRadius: 6, marginBottom: 12, fontSize: 13 }}>
          {error}
        </div>
      )}

      <div style={{ display: 'flex', gap: 8, marginBottom: 16 }}>
        {(['all', 'pending', 'escalated'] as StatusFilter[]).map((s) => (
          <button
            key={s}
            onClick={() => setFilter(s)}
            style={{
              padding: '4px 12px', borderRadius: 4, border: '1px solid #e2e8f0',
              background: filter === s ? '#6366f1' : '#f8fafc',
              color: filter === s ? '#fff' : '#374151',
              cursor: 'pointer', fontSize: 13,
            }}
          >
            {s.charAt(0).toUpperCase() + s.slice(1)}
          </button>
        ))}
        <span style={{ marginLeft: 'auto', fontSize: 13, color: '#64748b', alignSelf: 'center' }}>
          {visible.length} item{visible.length !== 1 ? 's' : ''}
        </span>
      </div>

      <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: 14 }}>
        <thead>
          <tr style={{ background: '#f8fafc', borderBottom: '2px solid #e2e8f0' }}>
            {['Agent', 'Domain', 'Submitted', 'Confidence', 'Quality', 'Status', ''].map((h) => (
              <th key={h} style={{ padding: '10px 12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>
                {h}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {visible.length === 0 && (
            <tr>
              <td colSpan={7} style={{ padding: '32px 12px', textAlign: 'center', color: '#94a3b8' }}>
                No {filter === 'all' ? '' : filter} items.
              </td>
            </tr>
          )}
          {visible.map((item) => (
            <ApprovalRow key={item.invocation_id} item={item} />
          ))}
        </tbody>
      </table>
    </div>
  );
}

function ApprovalRow({ item }: { item: ApprovalItem }) {
  const belowThreshold = mustGate(item);
  const scoreStyle = (score: number, threshold: number) => ({
    color: score <= threshold ? '#dc2626' : '#16a34a',
    fontWeight: 600,
  });

  return (
    <tr style={{ borderBottom: '1px solid #f1f5f9' }}>
      <td style={{ padding: '10px 12px' }}>{item.agent}</td>
      <td style={{ padding: '10px 12px' }}>{item.domain}</td>
      <td style={{ padding: '10px 12px', color: '#64748b', fontSize: 12 }}>
        {new Date(item.submitted_at).toLocaleString()}
      </td>
      <td style={{ padding: '10px 12px' }}>
        <span style={scoreStyle(item.confidence_score, APPROVAL_GATE.confidenceThreshold)}>
          {(item.confidence_score * 100).toFixed(0)}%
        </span>
      </td>
      <td style={{ padding: '10px 12px' }}>
        <span style={scoreStyle(item.quality_score, APPROVAL_GATE.qualityThreshold)}>
          {(item.quality_score * 100).toFixed(0)}%
        </span>
      </td>
      <td style={{ padding: '10px 12px' }}>
        <StatusBadge status={item.status} alert={belowThreshold} />
      </td>
      <td style={{ padding: '10px 12px' }}>
        <Link to={`/approval/${item.invocation_id}`}
              style={{ color: '#6366f1', textDecoration: 'none', fontWeight: 500 }}>
          Review →
        </Link>
      </td>
    </tr>
  );
}

function StatusBadge({ status, alert }: { status: ApprovalItem['status']; alert: boolean }) {
  const colors: Record<ApprovalItem['status'], string> = {
    pending:  '#fef3c7',
    escalated: '#fee2e2',
    cleared:  '#f1f5f9',
    approved: '#dcfce7',
    rejected: '#fee2e2',
  };
  return (
    <span style={{
      padding: '2px 8px', borderRadius: 12, fontSize: 12, fontWeight: 600,
      background: colors[status] ?? '#f1f5f9',
      outline: alert ? '2px solid #f59e0b' : 'none',
    }}>
      {status}
    </span>
  );
}
