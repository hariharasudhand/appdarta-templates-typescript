import axios from 'axios';
import type { ApprovalItem, ApprovalCallbackPayload } from '../config/approvalGate';
import { APPROVAL_GATE } from '../config/approvalGate';

const approvalHttp = axios.create({
  baseURL: APPROVAL_GATE.gatewayURL,
  headers: { 'Content-Type': 'application/json' },
});

approvalHttp.interceptors.request.use((config) => {
  const token = localStorage.getItem(APPROVAL_GATE.authTokenEnv) ??
                import.meta.env[`VITE_${APPROVAL_GATE.authTokenEnv}`];
  if (token) config.headers.Authorization = `Bearer ${token}`;
  return config;
});

/** Fetch all pending (and optionally escalated) approval items. */
export async function fetchPendingApprovals(): Promise<ApprovalItem[]> {
  const res = await approvalHttp.get<{ items: ApprovalItem[] }>('/gateway/api/approval/pending');
  return res.data.items ?? [];
}

/** Fetch a single approval item by invocation ID. */
export async function fetchApprovalItem(invocationId: string): Promise<ApprovalItem> {
  const res = await approvalHttp.get<ApprovalItem>(`/gateway/api/approval/${invocationId}`);
  return res.data;
}

/**
 * Submit an approval decision.
 * Always POSTs to /callbacks/approval — never /approve.
 *
 * Throws if the server returns 409 (already decided) — callers must handle
 * this case explicitly by refreshing the queue and showing a banner.
 */
export async function submitApprovalDecision(payload: ApprovalCallbackPayload): Promise<void> {
  await approvalHttp.post('/callbacks/approval', payload);
}
